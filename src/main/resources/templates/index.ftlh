<!DOCTYPE html>
<html>
<head>
    <title>Dragon Ball Character Gallery</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>

<nav>
    <a href="index.html">Home</a>
    <a href="details.html">Details</a>
    <a href="about.html">About</a>
    <a href="new-character-form.html">Add a Character</a>
</nav>

<h1>Character Gallery</h1>

<input type="text" placeholder="Search characters">

<div class="gallery">

    <div class="card">
        <img src="goku.jpeg" alt="Goku">
        <h2>Goku</h2>
        <p>Universe 7</p>
        <p>Main Hero</p>
        <p>Power Level: 9000+</p>
        <a href="details.html">View Details</a>
    </div>

    <div class="card">
        <img src="futuretrunks.jpeg" alt="Future Trunks">
        <h2>Future Trunks</h2>
        <p>Future Timeline</p>
        <p>Warrior</p>
        <p>Power Level: 8500+</p>
        <a href="details.html">View Details</a>
    </div>

    <div class="card">
        <img src="futuregohan.jpeg" alt="Future Gohan">
        <h2>Future Gohan</h2>
        <p>Future Timeline</p>
        <p>Mentor</p>
        <p>Power Level: 8000+</p>
        <a href="details.html">View Details</a>
    </div>

    <div class="card">
        <img src="vegeta.jpeg" alt="Vegeta">
        <h2>Vegeta</h2>
        <p>Universe 7</p>
        <p>Saiyan Prince</p>
        <p>Power Level: 8800+</p>
        <a href="details.html">View Details</a>
    </div>

    <div class="card">
        <img src="piccolo.jpeg" alt="Piccolo">
        <h2>Piccolo</h2>
        <p>Universe 7</p>
        <p>Namekian Warrior</p>
        <p>Power Level: 7500+</p>
        <a href="details.html">View Details</a>
    </div>

</div>

</body>
</html>